[server]
host = "localhost"
port = 5600
# Event types eligible for Odoo bucket-event sync.
bucket_allowlist = ["os.hid.input"]
# Also controls how often Odoo tracking state is refreshed.
poll_interval_secs = 10
lookback_secs = 300
batch_size = 200
state_file = ""

[odoo]
enabled = false
base_url = "http://localhost:8069"
pin_code = ""
employee_id = ""
device_id = ""
device_name = ""
timeout_secs = 10
# Set to false only for internal/dev Odoo hosts with broken or private CA chains.
verify_ssl = true
push_screenshots = true
push_metadata_events = false

[screenshot]
enabled = true
bucket_ids = ["aw-watcher-screenshot-mini*"]
# A scheduled target picks the nearest captured screenshot within this window.
selection_window_secs = 120

[logging]
enabled = true
dir = ""
level = "INFO"
to_stdout = true
to_file = true
rotate_when = "midnight"
rotate_interval = 1
backup_count = 14
filename = ""
